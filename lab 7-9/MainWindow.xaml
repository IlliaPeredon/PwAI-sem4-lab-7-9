<Window x:Class="Contacts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contacts" Height="500" Width="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL (LINQ BUTTONS) -->
        <StackPanel Grid.Column="0">

            <Button Content="Filter Age > 18" Click="Filter_Click" Margin="5"/>
            <Button Content="Sort by Name" Click="Sort_Click" Margin="5"/>
            <Button Content="Projection (Names)" Click="Project_Click" Margin="5"/>
            <Button Content="Any Age > 50" Click="Check_Click" Margin="5"/>
            <Button Content="Average Age" Click="Aggregate_Click" Margin="5"/>
            <Button Content="Show All" Click="ShowAll_Click" Margin="5"/>

            <TextBlock Text="{Binding AggregationResult}"
               Margin="5,20,5,5"
               FontWeight="Bold"/>

        </StackPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- INPUT -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                <StackPanel Margin="5">
                    <TextBlock Text="Name" Margin="0,0,0,2"/>
                    <TextBox Width="100" Text="{Binding SelectedContact.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Age" Margin="0,0,0,2"/>
                    <TextBox Width="50" Text="{Binding SelectedContact.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Email" Margin="0,0,0,2"/>
                    <TextBox Width="120" Text="{Binding SelectedContact.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="City" Margin="0,0,0,2"/>
                    <TextBox Width="100" Text="{Binding SelectedContact.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Telephone" Margin="0,0,0,2"/>
                    <TextBox Width="100" Text="{Binding SelectedContact.Telephone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Margin="5" Orientation="Horizontal">
                    <Button Content="Add" Width="70" Margin="5" Click="Add_Click"/>
                    <Button Content="Update" Width="70" Margin="5" Click="Update_Click"/>
                    <Button Content="Delete" Width="70" Margin="5" Click="Delete_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- TABLE -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ContactsView}"
                      SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="Age" Binding="{Binding Age}" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" />
                    <DataGridTextColumn Header="City" Binding="{Binding City}" />
                    <DataGridTextColumn Header="Telephone" Binding="{Binding Telephone}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ERROR LABEL -->
            <TextBlock Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       Margin="5"/>
        </Grid>
    </Grid>
</Window>